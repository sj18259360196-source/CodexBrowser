{
  "name": "codex-browser",
  "version": "1.1.0",
  "private": true,
  "description": "A visible, dedicated Microsoft Edge runtime for Codex with guarded browser and document tools.",
  "main": "dist/electron/main.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:renderer && npm run build:electron && npm run build:edge-prototype && npm run build:mcp",
    "build:renderer": "vite build",
    "build:electron": "tsup src/electron/main.ts src/electron/preload.ts src/electron/edge-control-center.ts --format cjs --out-dir dist/electron --clean --sourcemap --external electron",
    "build:mcp": "tsup src/mcp/index.ts --format esm --out-dir dist/mcp --clean --sourcemap",
    "build:edge-prototype": "tsup src/browser/edge-prototype-entry.ts src/browser/edge-broker.ts --format esm --out-dir dist/browser --clean --sourcemap",
    "start": "node scripts/start-runtime.mjs",
    "start:legacy": "set CODEX_BROWSER_RUNTIME=electron-legacy&& electron .",
    "package:win": "npm run build && node scripts/package-windows-portable.mjs",
    "package:installer": "npm run package:win && node scripts/package-windows-installer.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test:adapter": "tsc -p tests/tsconfig.browser-adapter.json && node --test .runtime/tests/browser-adapter/tests/browser-adapter.test.js",
    "test:tab-policy": "node --test --experimental-strip-types tests/tab-state-policy.test.ts",
    "test:auth-evidence": "node --test --experimental-strip-types tests/auth-evidence.test.ts",
    "test:challenge": "node --test --experimental-strip-types tests/challenge-detector.test.ts tests/assistance-coordinator.test.ts tests/verification-boundary.test.ts tests/pdf-response.test.ts",
    "test:persistence": "node --test --experimental-strip-types tests/persistence-validation.test.ts",
    "test:storage": "node --test --experimental-strip-types tests/data-confirmation.test.ts tests/edge-profile.test.ts tests/session-recovery-policy.test.ts",
    "test:policy": "node --test --experimental-strip-types tests/policy-engine.test.ts tests/action-authorization.test.ts",
    "test:runtime-selection": "node --test --experimental-strip-types tests/runtime-selection.test.ts",
    "test:edge-relay": "node --test --experimental-strip-types tests/extension-relay-server.test.ts",
    "test:launcher": "node --test tests/node-version.test.mjs",
    "test:release-info": "node --test --experimental-strip-types tests/release-info.test.ts",
    "test:unit": "npm run test:adapter && node --test --experimental-strip-types tests/action-authorization.test.ts tests/assistance-coordinator.test.ts tests/auth-evidence.test.ts tests/challenge-detector.test.ts tests/data-confirmation.test.ts tests/edge-profile.test.ts tests/extension-relay-server.test.ts tests/pdf-response.test.ts tests/persistence-validation.test.ts tests/policy-engine.test.ts tests/redaction.test.ts tests/release-info.test.ts tests/runtime-selection.test.ts tests/session-recovery-policy.test.ts tests/tab-state-policy.test.ts tests/verification-boundary.test.ts && npm run test:launcher",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "smoke:actions": "node scripts/browser-action-smoke.mjs",
    "smoke:runtime": "node scripts/runtime-control-smoke.mjs",
    "smoke:advanced": "node scripts/advanced-control-smoke.mjs",
    "smoke:edge": "npm run build:edge-prototype && node scripts/edge-prototype-smoke.mjs",
    "smoke:edge-core": "npm run build && node scripts/edge-core-smoke.mjs",
    "smoke:challenge": "npm run build && node scripts/challenge-assistance-smoke.mjs",
    "smoke:storage": "npm run build && node scripts/storage-profile-smoke.mjs",
    "smoke:policy": "npm run build && node scripts/policy-confirmation-smoke.mjs",
    "smoke:default-runtime": "npm run build && node scripts/default-runtime-smoke.mjs",
    "smoke:stability": "npm run build && node scripts/phase6-stability-smoke.mjs",
    "smoke:endurance": "npm run build && node scripts/phase7-endurance-smoke.mjs",
    "smoke:canary": "npm run build && node scripts/phase7-security-canary.mjs",
    "smoke:public-sites": "npm run build && node scripts/phase7-public-site-acceptance.mjs",
    "smoke:literature": "npm run build && node scripts/literature-download-smoke.mjs",
    "smoke:literature-batch": "npm run build && node scripts/literature-batch-smoke.mjs",
    "smoke:broker-recovery": "npm run build && node scripts/phase7-broker-recovery-smoke.mjs",
    "smoke:release-package": "node scripts/release-package-smoke.mjs",
    "smoke:installer": "node scripts/installer-smoke.mjs",
    "smoke:sensitive": "node scripts/sensitive-field-smoke.mjs",
    "smoke:tab-policy": "node scripts/tab-policy-smoke.mjs",
    "smoke:blocked-restart": "node scripts/blocked-state-restart-smoke.mjs",
    "test:redaction": "node --test --experimental-strip-types tests/redaction.test.ts",
    "test:sensitive": "npm run test:redaction && npm run smoke:sensitive"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^5.4.149",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
